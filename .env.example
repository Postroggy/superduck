# SuperDuck environment variables — example template
#
# Copy this file to `.env` (root of the repo) and fill in values as needed.
# `.env`, `.env.local`, and `.env.*.local` are gitignored.
#
# Nothing in this repo is required to *build* the Chrome extension or the
# native host — every variable below has a safe default or is only consumed
# by optional integrations (analytics, release builds, perf gating in CI).
# The Anthropic API key for the extension is supplied at runtime via the
# Options page UI, NOT via env.
#
# ─────────────────────────────────────────────────────────────────────────────
# chrome-native-host (Go) — product analytics (PostHog)
# Source: chrome-native-host/internal/analytics/posthog.go
# ─────────────────────────────────────────────────────────────────────────────

# PostHog project write key. When empty (the default for local dev), the
# native host's analytics package no-ops and emits zero events. Set this only
# when you intentionally want to send telemetry from your local build.
SUPERDUCK_POSTHOG_KEY=

# PostHog ingestion host. Leave empty to use the compiled-in default
# (https://us.i.posthog.com). Override for self-hosted PostHog or EU region.
SUPERDUCK_POSTHOG_HOST=

# Hard kill switch for analytics in the native host. Any of
# 1/true/yes/on disables event emission regardless of the key above.
SUPERDUCK_ANALYTICS_DISABLED=

# ─────────────────────────────────────────────────────────────────────────────
# chrome-native-host release builds — analytics key injection
# Source: chrome-native-host/Makefile
# ─────────────────────────────────────────────────────────────────────────────

# When `make release-binaries` (or any Makefile target that links analytics) runs with
# POSTHOG_KEY set, the value is baked into the binary via -ldflags -X. Leave
# empty for local development; set in CI via a repository/organization secret.
POSTHOG_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# chrome-crx test perf reporter
# Source: chrome-crx/scripts/test-perf-report.mjs
# ─────────────────────────────────────────────────────────────────────────────

# Threshold (ms) above which a vitest test is reported as "slow". Default 300.
SLOW_TEST_MS=300

# How many slowest tests to print in the perf report. Default 10.
TOP_N=10

# Hard-fail threshold (ms). When any test exceeds this, the perf script exits
# non-zero — useful as a CI guardrail. Default = SLOW_TEST_MS * 5. Set to 0
# to disable the gate entirely.
# NOTE: Leave fully commented out (not `FAIL_OVER_MS=`) — an empty value via
# dotenv parses as '' → NaN → would silently disable the gate.
# FAIL_OVER_MS=

# ─────────────────────────────────────────────────────────────────────────────
# Standard CI signal (used by the native host and chrome-crx tests)
# ─────────────────────────────────────────────────────────────────────────────

# Set to "true" / "1" by GitHub Actions and most CI providers automatically.
# The native host disables analytics when CI is truthy; vitest uses it to
# enable verbose + JUnit reporters. Do not set this manually for local dev.
# CI=
