# Dependencies
node_modules/

# Husky internal directory (regenerated by `npm install` via the prepare script)
.husky/_/
bun.lock
package-lock.json
yarn.lock
pnpm-lock.yaml

# Build output
dist/
build/
out/
*.crx
*.pem
*.zip

# npm release artifacts (generated by `make release-binaries` / `npm pack`)
npm/*.tgz
npm/packages/*/bin/superduck
npm/packages/*/bin/superduck.exe
npm/packages/*/bin/chrome-native-host
npm/packages/*/bin/chrome-native-host.exe

# Go
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out
# go.work is committed (defines the monorepo workspace). go.work.sum is local.
go.work.sum

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Cache
.cache/
.parcel-cache/
.eslintcache
*.tsbuildinfo

# Misc
.claude/
*.pem

# Test reports (timing/JUnit artifacts uploaded by CI)
test-results.junit.xml
chrome-native-host/test-results.json
chrome-crx/test-results.junit.xml
coverage/