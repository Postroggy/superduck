type MCPServer struct {
	udsConn net.Conn
}

func NewMCPServer() (*MCPServer, error) {
	var conn net.Conn
	var err error

	// Retry connection with timeout
	for i := 0; i < connectRetries; i++ {
		conn, err = net.DialTimeout("unix", udsPath, connectTimeout)
		if err == nil {
			break
		}
		slog.Warn("failed to connect to UDS", "attempt", i+1, "max", connectRetries, "error", err)
		if i < connectRetries-1 {
			time.Sleep(time.Second)
		}
	}

	if err != nil {
		return nil, fmt.Errorf("failed to connect to chrome-native-host at %s: %w\nMake sure chrome-native-host is running with --uds flag", udsPath, err)
	}

	slog.Info("connected to chrome-native-host", "path", udsPath)

	return &MCPServer{
		udsConn: conn,
	}, nil
}

func (s *MCPServer) forwardToNativeHost(tool string, args map[string]interface{}) (interface{}, error) {
	// Normalize arguments before forwarding
	args = s.normalizeArgs(tool, args)

	slog.Debug("forwarding to native host", "tool", tool, "args", args)
	// Send tool_request to native host
	req := map[string]interface{}{
		"type":   "tool_request",
		"method": "execute_tool",
		"params": map[string]interface{}{
			"tool": tool,
			"args": args,
		},
	}

	if err := sendMessage(s.udsConn, req); err != nil {
		return nil, fmt.Errorf("failed to send to native host: %w", err)
	}

	// Wait for tool_response
	response, err := readMessage(s.udsConn)
	if err != nil {
		return nil, fmt.Errorf("failed to read response: %w", err)
	}

	var resp ToolResponseMsg
	if err := json.Unmarshal(response, &resp); err != nil {
		return nil, fmt.Errorf("failed to parse response: %w", err)
	}

	if resp.Error != nil {
		return nil, fmt.Errorf("tool error: %v", resp.Error.Content)
	}

	// Debug log the result structure
	resultJSON, _ := json.Marshal(resp.Result.Content)
	slog.Debug("native host response", "result", string(resultJSON))

	return resp.Result.Content, nil
}

// normalizeArgs normalizes tool arguments to match Chrome extension expectations
func (s *MCPServer) normalizeArgs(tool string, args map[string]interface{}) map[string]interface{} {
	normalized := make(map[string]interface{})
	for k, v := range args {
		normalized[k] = v
	}

	// Handle computer tool duration parameter (convert milliseconds to seconds if needed)
	if tool == "computer" {
		if duration, ok := normalized["duration"].(float64); ok {
			// If duration > 30, assume it's in milliseconds and convert to seconds
			if duration > 30 {
				normalized["duration"] = duration / 1000
				slog.Debug("converted duration from milliseconds to seconds", "original", duration, "converted", normalized["duration"])
			}
			// Validate max duration
			if normalized["duration"].(float64) > 30 {
				slog.Warn("duration exceeds maximum", "duration", normalized["duration"], "max", 30)
			}
		}
	}

	return normalized
}

// convertToMCPContent converts Chrome tool response to MCP content format
func (s *MCPServer) convertToMCPContent(result interface{}) []interface{} {
	// If result is already an array, convert Anthropic format to MCP format
	if arr, ok := result.([]interface{}); ok {
		mcpContent := []interface{}{}

		for _, item := range arr {
			if m, ok := item.(map[string]interface{}); ok {
				itemType, hasType := m["type"].(string)
				if !hasType {
					continue // Skip items without type
				}

				switch itemType {
				case "text":
					// Text format is the same
					mcpContent = append(mcpContent, m)

				case "image":
					// Convert Anthropic format to MCP format
					if source, hasSource := m["source"].(map[string]interface{}); hasSource {
						if data, hasData := source["data"].(string); hasData {
							mimeType := "image/png"
							if mt, hasMT := source["media_type"].(string); hasMT {
								mimeType = mt
							}
							mcpContent = append(mcpContent, map[string]interface{}{
								"type":     "image",
								"data":     data,
								"mimeType": mimeType,
							})
							continue
						}
					}
					// If already in MCP format, keep it
					if _, hasData := m["data"]; hasData {
						mcpContent = append(mcpContent, m)
					}

				default:
					// Keep other types as-is
					mcpContent = append(mcpContent, m)
				}
			}
		}

		return mcpContent
	}

	// Convert map result to MCP content
	if m, ok := result.(map[string]interface{}); ok {
		content := []interface{}{}

		// Handle screenshot response with base64Image
		if base64Image, hasImage := m["base64Image"].(string); hasImage {
			// Add text output if present
			if output, hasOutput := m["output"].(string); hasOutput {
				content = append(content, map[string]interface{}{
					"type": "text",
					"text": output,
				})
			}

			// Add image
			imageFormat := "png"
			if format, ok := m["imageFormat"].(string); ok {
				imageFormat = format
			}

			content = append(content, map[string]interface{}{
				"type":     "image",
				"data":     base64Image,
				"mimeType": "image/" + imageFormat,
			})

			return content
		}

		// Handle regular output response
		if output, hasOutput := m["output"].(string); hasOutput {
			return []interface{}{
				map[string]interface{}{
					"type": "text",
					"text": output,
				},
			}
		}

		// Handle error response
		if errMsg, hasError := m["error"].(string); hasError {
			return []interface{}{
				map[string]interface{}{
					"type": "text",
					"text": "Error: " + errMsg,
				},
			}
		}
	}

	// Fallback: convert to JSON string
	jsonBytes, _ := json.Marshal(result)
	return []interface{}{
		map[string]interface{}{
			"type": "text",
			"text": string(jsonBytes),
		},
	}
}

func (s *MCPServer) handleRequest(req MCPRequest) MCPResponse {
	slog.Debug("handling request", "method", req.Method, "id", req.ID)

	switch req.Method {
	case "initialize":
		return MCPResponse{
			JSONRPC: "2.0",
			ID:      req.ID,
			Result: map[string]interface{}{
				"protocolVersion": "2024-11-05",
				"capabilities": map[string]interface{}{
					"tools": map[string]interface{}{},
				},
				"serverInfo": map[string]interface{}{
					"name":    "chrome-mcp-server",
					"version": "1.0.0",
				},
			},
		}

	case "tools/list":
		return MCPResponse{
			JSONRPC: "2.0",
			ID:      req.ID,
			Result: map[string]interface{}{
				"tools": chromeTools,
			},
		}

	case "tools/call":
		var params ToolsCallParams
		if err := json.Unmarshal(req.Params, &params); err != nil {
			return MCPResponse{
				JSONRPC: "2.0",
				ID:      req.ID,
				Error: &MCPError{
					Code:    -32602,
					Message: fmt.Sprintf("Invalid params: %v", err),
				},
			}
		}

		result, err := s.forwardToNativeHost(params.Name, params.Arguments)
		if err != nil {
			return MCPResponse{
				JSONRPC: "2.0",
				ID:      req.ID,
				Error: &MCPError{
					Code:    -32603,
					Message: err.Error(),
				},
			}
		}

		// Convert result to MCP content format
		content := s.convertToMCPContent(result)

		return MCPResponse{
			JSONRPC: "2.0",
			ID:      req.ID,
			Result: map[string]interface{}{
				"content": content,
			},
		}

	default:
		return MCPResponse{
			JSONRPC: "2.0",
			ID:      req.ID,
			Error: &MCPError{
				Code:    -32601,
				Message: fmt.Sprintf("Method not found: %s", req.Method),
			},
		}
	}
}

func (s *MCPServer) Run() error {
	scanner := bufio.NewScanner(os.Stdin)

	for scanner.Scan() {
		line := scanner.Bytes()

		var req MCPRequest
		if err := json.Unmarshal(line, &req); err != nil {
			slog.Error("failed to parse request", "error", err)
			continue
		}

		resp := s.handleRequest(req)

		respBytes, err := json.Marshal(resp)
		if err != nil {
			slog.Error("failed to marshal response", "error", err)
			continue
		}

		fmt.Println(string(respBytes))
	}

	return scanner.Err()
}

func (s *MCPServer) Close() error {
	if s.udsConn != nil {
		return s.udsConn.Close()
	}
	return nil
}

func main() {
	logFile, err := os.OpenFile("/tmp/chrome-mcp-server.log", os.O_CREATE|os.O_WRONLY|os.O_APPEND, 0644)
	if err != nil {
		fmt.Fprintf(os.Stderr, "failed to open log file: %v\n", err)
		os.Exit(1)
	}
	defer logFile.Close()

	logger := slog.New(slog.NewJSONHandler(logFile, &slog.HandlerOptions{
		Level: slog.LevelDebug,
	}))
	slog.SetDefault(logger)

	slog.Info("MCP Server started")

	server, err := NewMCPServer()
	if err != nil {
		slog.Error("failed to create MCP server", "error", err)
		os.Exit(1)
	}
	defer server.Close()

	if err := server.Run(); err != nil {
		slog.Error("server error", "error", err)
		os.Exit(1)
	}
}
