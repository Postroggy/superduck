{
  "name": "superduck-chrome-crx",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,json}\" \"eslint.config.js\" \"package.json\" \"tsconfig.json\" \".prettierrc.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,json}\" \"eslint.config.js\" \"package.json\" \"tsconfig.json\" \".prettierrc.json\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "test:perf": "vitest run --reporter=verbose --reporter=junit --outputFile.junit=test-results.junit.xml",
    "test:perf:report": "node scripts/test-perf-report.mjs test-results.junit.xml",
    "test:e2e": "npx playwright test --config e2e/playwright.config.ts",
    "test:e2e:ui": "npx playwright test --config e2e/playwright.config.ts --ui",
    "docs": "typedoc --options typedoc.json",
    "docs:check": "typedoc --options typedoc.json --emit none"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@growthbook/growthbook-react": "^1.2.0",
    "@honeycombio/opentelemetry-web": "^1.1.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@opentelemetry/api": "^1.9.0",
    "@radix-ui/react-popover": "^1.1.0",
    "@radix-ui/react-select": "^2.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.0",
    "@sentry/browser": "^10.22.0",
    "@statsig/js-client": "^3.32.0",
    "@statsig/react-bindings": "^3.32.0",
    "@tanstack/react-query": "^5.60.0",
    "@tanstack/react-virtual": "^3.13.23",
    "@tiptap/core": "^3.23.1",
    "@tiptap/extension-placeholder": "^3.20.0",
    "@tiptap/pm": "^3.23.1",
    "@tiptap/react": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.20.0",
    "@types/react-syntax-highlighter": "^15.5.13",
    "border-beam": "^1.0.1",
    "buffer": "^6.0.3",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "diff": "^9.0.0",
    "framer-motion": "^12.38.0",
    "katex": "^0.16.33",
    "lodash": "^4.17.23",
    "lucide-react": "^0.525.0",
    "luxon": "^3.5.0",
    "openai": "6.38.0",
    "punycode": "^2.3.1",
    "react": "^19.2.4",
    "react-calendar": "^6.0.1",
    "react-dom": "^19.2.4",
    "react-intl": "^7.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "refractor": "^5.0.0",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tippy.js": "^6.3.7",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.33",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "4.2.4",
    "@types/chrome": "^0.1.37",
    "@types/diff": "^8.0.0",
    "@types/lodash": "^4.17.0",
    "@types/luxon": "^3.4.0",
    "@types/react": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "prettier": "^3.8.1",
    "tailwindcss": "4.2.4",
    "typedoc": "^0.28.19",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.1.5",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.0.0"
  },
  "description": "",
  "main": "eslint.config.js",
