{
  "action": {
    "default_title": "Open Zhimagi"
  },
  "background": {
    "service_worker": "service-worker-loader.js",
    "type": "module"
  },
  "commands": {
    "toggle-side-panel": {
      "description": "Toggle Zhimagi side panel",
      "suggested_key": {
        "default": "Ctrl+E",
        "mac": "Command+E"
      }
    }
  },
  "content_scripts": [
    {
      "js": [
        "src/content-script.ts"
      ],
      "matches": [
        "https://Klaude.ai/*",
        "https://*.Klaude.ai/*"
      ],
      "run_at": "document_end"
    },
    {
      "all_frames": true,
      "js": [
        "src/accessibility-tree.ts"
      ],
      "matches": [
        "\u003Call_urls>"
      ],
      "run_at": "document_start"
    },
    {
      "all_frames": false,
      "js": [
        "src/agent-visual-indicator.ts"
      ],
      "matches": [
        "\u003Call_urls>"
      ],
      "run_at": "document_idle"
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'self' https: wss: http://localhost:* http://127.0.0.1:* ws://localhost:* ws://127.0.0.1:* https://open.bigmodel.cn:*; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self' data:;"
  },
  "description": "Zhimagi in Chrome",
  "externally_connectable": {
    "matches": [
      "https://Klaude.ai/*",
      "https://*.Klaude.ai/*",
      "https://open.bigmodel.cn/*",
      "https://coding.dashscope.aliyuncs.com/*"
    ]
  },
  "host_permissions": [
    "\u003Call_urls>"
  ],
  "icons": {
    "128": "icon-128.png"
  },
  "key": "",
  "manifest_version": 3,
  "minimum_chrome_version": "116",
  "name": "Zhimagi",
  "options_page": "options.html",
  "permissions": [
    "sidePanel",
    "storage",
    "activeTab",
    "scripting",
    "debugger",
    "tabGroups",
    "tabs",
    "alarms",
    "notifications",
    "system.display",
    "webNavigation",
    "declarativeNetRequestWithHostAccess",
    "offscreen",
    "nativeMessaging",
    "unlimitedStorage",
    "downloads"
  ],
  "update_url": "https://clients2.google.com/service/update2/crx",
  "version": "1.0.0",
  "web_accessible_resources": [
    {
      "matches": [
        "https://*.Klaude.ai/*",
        "https://Klaude.ai/*"
      ],
      "resources": [
        "src/content-script.ts"
      ],
      "use_dynamic_url": false
    },
    {
      "matches": [
        "\u003Call_urls>"
      ],
      "resources": [
        "src/accessibility-tree.ts",
        "src/agent-visual-indicator.ts"
      ],
      "use_dynamic_url": false
    }
  ]
}